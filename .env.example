# IRONCLAW BTC Node Configuration
# Copy to .env and fill in your values

# --- Bitcoin Core RPC ---
BTC_RPC_HOST=127.0.0.1
BTC_RPC_PORT=8332
BTC_RPC_USER=bitcoinrpc
BTC_RPC_PASS=your_bitcoin_rpc_password

# --- LND (Lightning Network Daemon) ---
# Only needed if you run LND locally for L402 payments
LND_DIR=/path/to/lnd/data

# --- Wallet (for x402 USDC payments) ---
# The wallet address that receives USDC payments on Base
WALLET=0x6a667a72d3d36d95421474019aa46f0308d643fc

# --- Server ---
PORT=3100
BASE_URL=http://127.0.0.1:4021

# --- Optional: External API keys for premium tools ---
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

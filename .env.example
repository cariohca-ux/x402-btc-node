# x402 Bitcoin Node Server — Configuration

# === REQUIRED: Your receiving wallet (USDC on Base) ===
# Create a Coinbase wallet or any EVM wallet with USDC on Base network
# This is where payments from AI agents will be sent
# Example: 0xABCDEF1234567890ABCDEF1234567890ABCDEF12
WALLET_ADDRESS=

# === OPTIONAL: Server settings ===
PORT=4021
NODE_ENV=production

# === Bitcoin Core RPC (localhost — no changes needed) ===
# These should match your bitcoin.conf. Defaults are standard for local node.
BITCOIN_RPC_HOST=127.0.0.1
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_USER=bitcoinrpc
BITCOIN_RPC_PASS=aa6071c7d504c891bc98022a715af0481ea66601fc5579819b083a4e5177056a
BITCOIN_RPC_TIMEOUT=5000

# === Rate limiting ===
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
